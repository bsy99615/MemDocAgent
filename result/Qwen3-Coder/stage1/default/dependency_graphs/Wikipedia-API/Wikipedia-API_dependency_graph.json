  "wikipediaapi.__init__.Wikipedia.page": {
    "id": "wikipediaapi.__init__.Wikipedia.page",
    "component_type": "method",
    "file_path": "/repos/Communications/Wikipedia-API/wikipediaapi/__init__.py",
